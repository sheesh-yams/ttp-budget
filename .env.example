# ─── Database ────────────────────────────────────────────────────────────────
# Get from: https://neon.tech → New project → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@ep-xyz.us-east-2.aws.neon.tech/ttp-budget?sslmode=require"

# ─── Clerk Auth ───────────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → Your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Email ────────────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="The Third Place Creative <proposals@yourdomain.com>"

# ─── File Storage ─────────────────────────────────────────────────────────────
# Get from: Vercel dashboard → Storage → Blob → Create store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── App ──────────────────────────────────────────────────────────────────────
# Your deployed URL (no trailing slash). Used for public proposal/invoice links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# In production:
# NEXT_PUBLIC_APP_URL="https://budget.thethirdplace.co"
