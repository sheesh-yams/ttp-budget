# ─── Database ────────────────────────────────────────────────────────────────
# Get from: https://neon.tech → New project → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@ep-xyz.us-east-2.aws.neon.tech/ttp-budget?sslmode=require"

# ─── Clerk Auth ───────────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → Your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Email ────────────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="The Third Place Creative <proposals@yourdomain.com>"

# ─── File Storage (Cloudflare R2) ────────────────────────────────────────────
# Cloudflare dashboard → R2 → Manage R2 API tokens → Create API token (Object Read & Write)
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=slatesuite
# Public read URL — Cloudflare dashboard → R2 → your bucket → Settings → Public access
# Use a custom domain (e.g. assets.yourdomain.com) or the r2.dev subdomain
NEXT_PUBLIC_R2_PUBLIC_URL=https://assets.yourdomain.com

# ─── Payments — credential encryption ────────────────────────────────────────
# Helcim credentials are stored per-workspace, AES-256-GCM encrypted in the DB.
# See Settings → Payments (entitled workspaces only) to configure them via UI.
#
# The KEK (key-encryption key) protects those encrypted DB rows.
# Generate: openssl rand -base64 32
# NEVER change an existing KEK value — add a new version and run:
#   npx tsx scripts/rotate-credential-kek.ts --apply
CREDENTIAL_KEK_V1=""

# ─── Payments — Stripe Connect (Phase 3 — platform-level, shared by all) ─────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_CLIENT_ID=""

# ─── Payments (Helcim — legacy env-var path, to be removed after TTP migration) ─
# These are used only until The Third Place workspace is migrated to per-workspace
# encrypted credentials via scripts/migrate-ttp-helcim.ts.
# Do NOT set these for new workspaces.
HELCIM_API_TOKEN=
HELCIM_WEBHOOK_VERIFIER_TOKEN=

# ─── Shade (delivery thumbnail provider) ─────────────────────────────────────
# Get from: Shade dashboard → Settings → API → Create API key
# Format: sk_... (passed directly in the Authorization header without "Bearer")
SHADE_API_KEY=sk_...

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Create a database at console.upstash.com → New Database (Global, free tier).
# Copy the REST URL + token from the database's "REST API" tab.
# App falls back to in-process memory limiter when these are unset (local dev).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── App ──────────────────────────────────────────────────────────────────────
# Your deployed URL (no trailing slash). Used for public proposal/invoice links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# In production:
# NEXT_PUBLIC_APP_URL="https://budget.thethirdplace.co"
