// The Third Place Creative — Budgeting & Invoicing
// Prisma schema. Postgres on Neon.
//
// Design notes:
// - Multi-tenant: each workspace is owned by one Clerk org. clerkOrgId links them.
// - Money stored as Int cents (avoid float drift). Convert at the edges.
// - Soft delete via `archived_at` on the things you'd want to recover (projects, clients, rate cards).
//   Hard delete is allowed on line items, accounts, phases — those churn too much for soft delete.
// - Snapshots: line items reference a RateCard but copy `description`, `unit`, `rate` at insert time.
//   Updating a rate card never mutates historical budgets.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// WORKSPACE & USERS
// =============================================================

model Workspace {
  id                String   @id @default(cuid())
  name              String   // "The Third Place Creative"
  legalName         String?  // for invoices: "The Third Place Creative LLC"
  ein               String?  // tax ID for invoices
  addressLine1      String?
  addressLine2      String?
  city              String?
  region            String?  // state/province
  postalCode        String?
  country           String?  @default("US")
  contactEmail      String?
  contactPhone      String?
  website           String?

  // Branding (used by proposal/invoice templates)
  logoUrl           String?  // light bg version
  logoDarkUrl       String?  // dark bg version
  primaryColor      String   @default("#5D00A4") // SlateSuite brand purple
  accentColor       String   @default("#04FFCC") // SlateSuite brand mint
  bodyFont          String   @default("Inter")
  displayFont       String   @default("Inter")

  // Defaults that flow into new budgets/invoices
  defaultMarkupPct  Decimal  @default(0)        @db.Decimal(6, 4) // e.g. 0.20 = 20%
  defaultTaxPct     Decimal  @default(0)        @db.Decimal(6, 4)
  defaultPaymentTermsDays Int @default(30)
  invoiceNumberPrefix String @default("TTP")    // TTP-2026-001
  invoiceNumberSeq  Int      @default(0)        // last issued seq for current year
  invoiceNumberYear Int?

  // Payment instructions shown on invoice public page
  wireInstructions  String?  @db.Text
  achInstructions   String?  @db.Text
  checkPayableTo    String?
  checkMailingAddress String? @db.Text

  // Default proposal/invoice terms text
  defaultProposalTerms String? @db.Text
  defaultInvoiceTerms  String? @db.Text

  // Auto-expiry defaults (days from creation/send)
  proposalExpiryDays Int @default(30)
  invoiceExpiryDays  Int @default(30)

  // Production preferences
  callTimeFormat    String   @default("12H")  // "12H" → "7:00 AM" | "24H" → "07:00"

  // Clerk organization that owns this workspace (set after org creation webhook)
  clerkOrgId        String?  @unique

  // Soft-delete: set at deletion request; hard-purged after 30-day grace via Vercel Cron.
  deletedAt         DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users             User[]
  clients           Client[]
  projects          Project[]
  rateCards         RateCard[]
  templates         BudgetTemplate[]
  budgets           Budget[]
  proposals         Proposal[]
  invoices          Invoice[]
  callSheets        CallSheet[]
  actualSheets      ActualSheet[]
  invitations       WorkspaceInvitation[]
  contacts          Contact[]
  paymentConfig            WorkspacePaymentConfig?
  receipts                 Receipt[]
  contractBlocks           ContractBlock[]
  autoAttachContractBlocks Boolean @default(false)
}

enum UserRole {
  OWNER         // org:admin — full access, billing, danger zone, member mgmt
  PRODUCER      // full CRUD on projects/budgets, no workspace settings/members
  COLLABORATOR  // only assigned projects; budgets are margin-blind; can edit call sheets
}

model User {
  id           String   @id @default(cuid())
  clerkId      String   @unique // mapped from Clerk
  email        String   @unique
  name         String?
  avatarUrl    String?
  role         UserRole @default(PRODUCER)
  onboarded    Boolean  @default(false)

  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdProjects  Project[]   @relation("ProjectCreatedBy")
  createdBudgets   Budget[]    @relation("BudgetCreatedBy")
  createdProposals Proposal[]  @relation("ProposalCreatedBy")
  createdInvoices  Invoice[]   @relation("InvoiceCreatedBy")
  projectComments  ProjectComment[] @relation("ProjectCommentAuthor")
  projectAssignments ProjectAssignment[]
  projectTeamMembers ProjectTeamMember[]

  @@index([workspaceId])
}

// =============================================================
// CLIENTS & PROJECTS
// =============================================================

model Client {
  id             String   @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name           String   // "Hulu", "Tiffany & Co."
  legalName      String?  // legal entity for invoices (e.g. "Hulu, LLC")
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  billingAddress String?  @db.Text
  logoUrl        String?  // optional, for co-branded proposals
  website        String?
  specialNotes   String?  @db.Text  // high-priority account callouts shown on the CRM card
  notes          String?  @db.Text

  archivedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projects       Project[]
  invoices       Invoice[]

  @@index([workspaceId])
  @@index([workspaceId, archivedAt])
}

enum ShootType {
  MUSIC_VIDEO
  BRAND_CAMPAIGN
  PRODUCT_SHOOT
  EVENT_RECAP
  SOCIAL_CONTENT
  INFLUENCER
  DOCUMENTARY
  OTHER
}

enum ProjectStatus {
  LEAD
  ACTIVE
  WRAPPED
  ARCHIVED
}

model Project {
  id             String   @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)

  name           String   // "Hulu — Summer 2026 Sizzle"
  code           String?  // optional internal code, e.g. "HUL-26-SUM"
  shootType      ShootType @default(OTHER)
  status         ProjectStatus @default(LEAD)
  shootStartDate DateTime?
  shootEndDate   DateTime?
  coverImageUrl  String?
  description    String?  @db.Text
  notes          String?  @db.Text

  createdById    String?
  createdBy      User?    @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  archivedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  budgets        Budget[]
  proposals      Proposal[]
  invoices       Invoice[]
  callSheets     CallSheet[]
  actualSheets   ActualSheet[]
  projectMembers ProjectMember[]
  receipts       Receipt[]
  comments       ProjectComment[]
  assignments    ProjectAssignment[]
  teamMembers    ProjectTeamMember[]
  deliveryPage   DeliveryPage?
  shootDays      ShootDay[]
  scenes         Scene[]
  schedules      Schedule[]

  @@index([workspaceId])
  @@index([clientId])
  @@index([workspaceId, status])
}

// ─── Project ↔ App-user assignment (RBAC visibility for Collaborators) ─────────
// Owners/Producers see every project in the workspace. A Collaborator only sees
// projects where a row links them here. Distinct from ProjectMember (which is
// crew/Contact-based call-sheet data, not app-user access control).
model ProjectAssignment {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Denormalized for tenant isolation — auto-injected by getScopedDb().
  workspaceId String

  createdAt   DateTime @default(now())

  @@unique([projectId, userId])
  @@index([userId])
  @@index([workspaceId])
}

// ─── Internal project team (workspace users in named roles) ──────────────────
enum ProjectTeamRole {
  PROJECT_LEAD
  ACCOUNT_MANAGER
  PROJECT_MANAGER
}

model ProjectTeamMember {
  id                 String          @id @default(cuid())
  workspaceId        String
  projectId          String
  project            Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId             String
  user               User            @relation(fields: [userId], references: [id])
  role               ProjectTeamRole
  assignedAt         DateTime        @default(now())
  assignedByUserId   String?
  unassignedAt       DateTime?
  unassignedByUserId String?
  unassignReason     String?         // 'REPLACED' | 'REMOVED' | 'USER_LEFT_WORKSPACE'

  @@index([projectId, role])
  @@index([userId])
  @@index([workspaceId])
  @@index([projectId, unassignedAt])
}

// ─── Project activity / comment thread ────────────────────────────────────────
// A scrollable, ClickUp-style feed of comments on a project. Replaces the old
// single static `Project.notes` textarea (legacy notes are surfaced as the first
// item in the thread by getProjectActivity rather than migrated destructively).
model ProjectComment {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Denormalized for tenant isolation — auto-injected by getScopedDb().
  workspaceId String

  // Author = User.id (our local user row, mapped from Clerk). Resolved to
  // name/avatar via the author relation.
  authorId    String
  author      User     @relation("ProjectCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  content     String   @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, createdAt])
  @@index([workspaceId])
}

// =============================================================
// RATE CARDS — the master list
// =============================================================

enum RateCategory {
  CREW
  EQUIPMENT
  POST
  LOCATION
  TALENT
  TRAVEL
  CATERING
  INSURANCE
  PRODUCTION_FEE
  MISC
}

enum RateUnit {
  HOUR
  HALF_DAY
  DAY
  WEEK
  FLAT
  EACH
  MILE
}

// Broad call-sheet / import category — auto-populated from RateCard.category at insert time.
// Intentionally simpler than RateCategory: used internally for crew import, not shown in UI.
enum LineItemCategory {
  CREW        // line item represents a person on set (DP, gaffer, PA, talent, etc.)
  LOCATION    // location fee, permit, scout
  EQUIPMENT   // camera, grip, lighting, vehicles
  SERVICE     // travel, catering, insurance, production fee, post services
  DELIVERABLE // final deliverable: edit, color, mix, VFX — NOT a crew member
}

model RateCard {
  id            String   @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  role          String   // "Videographer", "Gaffer", "1st AC", "RED Komodo Package"
  category      RateCategory
  defaultUnit   RateUnit @default(DAY)
  defaultRateCents Int   // money in cents
  notes         String?  @db.Text

  // For autocomplete ranking + filtering
  searchTokens  String?  // pre-computed lowercase tokens; updated on save
  isFavorite    Boolean  @default(false)
  usageCount    Int      @default(0) // incremented when added to a budget line; powers "frequently used" sort

  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lineItems     LineItem[]

  @@index([workspaceId])
  @@index([workspaceId, category])
  @@index([workspaceId, archivedAt])
}

// =============================================================
// BUDGET TEMPLATES — saved skeletons
// =============================================================

model BudgetTemplate {
  id            String       @id @default(cuid())
  workspaceId   String
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name          String       // "Music Video — Standard Crew"
  description   String?      @db.Text
  kind          TemplateKind @default(FULL)      // FULL = complete project blueprint; PACKAGE = add-on building block
  shootType     ShootType    @default(OTHER)     // primary type (used for auto-selection in NewProjectModal)
  tags          Json         @default("[]")      // ShootType[] — multi-select subtypes for discoverability

  // Stored as a JSON tree of accounts + line items.
  // Materialized into real rows when a Budget is created from this template.
  // Shape: { accounts: [{ id, name, code, items: [{ id, description, rateCardId?, qty, unit, rateCents, markupPct, notes }], children: [...] }] }
  structure     Json         @default("{\"accounts\":[]}")

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([workspaceId])
}

enum TemplateKind {
  FULL     // Complete project budget — used to seed a new project's budget
  PACKAGE  // Add-on building block — inserted into an existing budget phase
}

// =============================================================
// BUDGETS — Phases, Accounts, Line Items
// =============================================================

model Budget {
  id            String   @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name          String   // "Main Budget" — usually just one per project, but you can have more
  notes         String?  @db.Text

  // Globals: { shoot_days: 2, prep_days: 1, post_days: 5, ... } — referenced in formulas
  globals       Json     @default("{}")

  // Default markup/tax applied at budget level (overrides workspace default)
  markupPct     Decimal? @db.Decimal(6, 4)
  taxPct        Decimal? @db.Decimal(6, 4)

  createdById   String?
  createdBy     User?    @relation("BudgetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  phases        Phase[]
  proposals     Proposal[]
  invoices      Invoice[]
  actualSheets  ActualSheet[]

  @@index([projectId])
  @@index([workspaceId])
}

model Phase {
  id            String   @id @default(cuid())
  budgetId      String
  budget        Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  // Denormalized for IDOR protection — backfilled via scripts/backfill-workspace-ids.ts.
  // Nullable during migration; all new rows have it set via getScopedDb().
  workspaceId   String?

  name          String   // "v1 Client Send", "v2 With Notes", "Approved"
  order         Int      @default(0)
  isLocked      Boolean  @default(false) // approved phases get locked
  isPrimary     Boolean  @default(false) // the one used by default for proposals/invoices

  // Proposal overview — editable per budget version
  overview      String?  @db.Text  // short tagline shown on cover
  description   String?  @db.Text  // full description shown in "The Project" body
  deliverables  Json?    // [{title: string, description: string, number?: string}]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sections                  BudgetSection[]
  accounts                  Account[]
  pageBreakBetweenAccounts  Boolean   @default(false)
  sectionsNudgeDismissedAt  DateTime?

  @@index([budgetId])
  @@index([workspaceId])
  @@unique([budgetId, name])
}

model BudgetSection {
  id           String   @id @default(cuid())
  workspaceId  String   // denormalized for getScopedDb() — REQUIRED
  phaseId      String
  phase        Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  orderIndex   Int      @default(0)
  accounts     Account[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([phaseId, orderIndex])
  @@index([workspaceId])
}

model Account {
  id            String        @id @default(cuid())
  phaseId       String
  phase         Phase         @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  sectionId     String        // NOT NULL; source of truth for grouping; phaseId is denormalized shortcut
  section       BudgetSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  // Self-referencing tree
  parentId      String?
  parent        Account? @relation("AccountTree", fields: [parentId], references: [id], onDelete: Cascade)
  children      Account[] @relation("AccountTree")

  // Denormalized for IDOR protection — backfilled via scripts/backfill-workspace-ids.ts.
  workspaceId   String?

  name          String   // "Pre-Production", "Crew", "Camera Package"
  code          String?  // optional account code, "1000", "1100"
  order         Int      @default(0)
  notes         String?  @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lineItems     LineItem[]

  @@index([phaseId])
  @@index([sectionId])
  @@index([parentId])
  @@index([workspaceId])
}

model LineItem {
  id            String   @id @default(cuid())
  accountId     String
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Denormalized for IDOR protection — backfilled via scripts/backfill-workspace-ids.ts.
  workspaceId   String?

  // Snapshot from RateCard at insert time. rateCardId is nullable for ad-hoc lines.
  rateCardId    String?
  rateCard      RateCard? @relation(fields: [rateCardId], references: [id], onDelete: SetNull)

  // Optional Rolodex contact fulfilling this line item (crew use only).
  // Financially inert — rate is already snapshotted into rateCents.
  // Drives auto-upsert of ProjectMember on the Teams page when category = CREW.
  contactId     String?
  contact       Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  description   String   // editable; defaults to rateCard.role
  quantity      Decimal  @db.Decimal(12, 4) @default(1)
  unit          RateUnit @default(DAY)
  rateCents     Int      // money in cents; snapshot from rate card, manually adjustable
  markupPct     Decimal? @db.Decimal(6, 4) // optional per-line markup override
  hasMarkup     Boolean  @default(true)    // whether the budget-level agency fee applies to this item
  taxRate       Decimal? @db.Decimal(6, 4) // per-item tax rate override (null = no per-item tax; use budget.taxPct for global)
  notes         String?  @db.Text

  // Optional formula string for quantity, e.g. "shoot_days + 1". If set, qty is computed.
  quantityFormula String?

  // Broad category — snapshot from RateCard.category at insert time via mapping.
  // Null for ad-hoc items with no rate card. Never shown in client UI.
  lineItemCategory LineItemCategory?

  // Tags for filtering — array of strings
  tags          String[]

  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([accountId])
  @@index([rateCardId])
  @@index([contactId])
  @@index([workspaceId])
}

// =============================================================
// PROPOSALS — client-facing presentations
// =============================================================

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  CHANGES_NEEDED  // client has requested revisions
  APPROVED
  DECLINED
  EXPIRED
  LOST            // deal lost — manually marked by the user
}

enum ProposalDetailLevel {
  SUMMARY      // totals by account only
  ITEMIZED     // every line item visible
  HYBRID       // top accounts itemized, the rest summarized
}

model Proposal {
  id            String   @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetId      String
  budget        Budget   @relation(fields: [budgetId], references: [id], onDelete: Restrict)
  phaseId       String?  // which phase to render; defaults to primary

  // Identity & sharing
  title         String   // "Hulu — Summer 2026 Sizzle Proposal"
  publicToken   String   @unique @default(dbgenerated("gen_random_uuid()::text")) // /p/[publicToken]
  version       Int      @default(1)

  // Content — JSON so we can iterate on shape without migrations
  // { cover: {...}, sections: [{ type: 'about'|'scope'|'budget'|'terms'|'custom', ... }] }
  content       Json     @default("{}")
  detailLevel   ProposalDetailLevel @default(SUMMARY)

  // Brand overrides — null = inherit from workspace
  brandOverrides Json?   // { primaryColor?, accentColor?, logoUrl?, useClientLogo?, ... }

  // Status & lifecycle
  status        ProposalStatus @default(DRAFT)
  sentAt        DateTime?
  expiresAt     DateTime?      // client signature deadline (business logic)
  publicTokenExpiresAt DateTime? // when the public /p/[token] URL stops working (null = never)
  firstViewedAt DateTime?
  lastViewedAt  DateTime?
  viewCount     Int      @default(0)

  // Approval (typed signature)
  approvedAt    DateTime?
  signatureName String?  // typed name
  signatureIp   String?
  declinedAt    DateTime?
  declineReason String?  @db.Text

  // Snapshot of the totals at time of approval — preserves the number the client agreed to
  approvedTotalCents Int?

  // Contract section toggle — when false no Terms section appears on the public view
  contractEnabled Boolean @default(true)

  createdById   String?
  createdBy     User?    @relation("ProposalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  views            ProposalView[]
  contractSections ProposalContractSection[]

  @@index([projectId])
  @@index([workspaceId])
  @@index([status])
}

// Track every public page view (for "client just opened your proposal" notifications)
model ProposalView {
  id           String   @id @default(cuid())
  proposalId   String
  proposal     Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  viewedAt     DateTime @default(now())
  ip           String?
  userAgent    String?  @db.Text
  referer      String?

  @@index([proposalId])
}

// =============================================================
// INVOICES
// =============================================================

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  VOID
}

enum InvoiceKind {
  DEPOSIT       // e.g. 50% upfront
  PROGRESS      // milestone
  FINAL         // remainder
  STANDALONE    // not tied to a specific budget structure
}

model Invoice {
  id            String   @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetId      String?
  budget        Budget?  @relation(fields: [budgetId], references: [id], onDelete: SetNull)

  // Identity & sharing
  number        String   // "TTP-2026-001" — unique per workspace
  publicToken   String   @unique @default(dbgenerated("gen_random_uuid()::text")) // /i/[publicToken]
  kind          InvoiceKind @default(STANDALONE)

  title         String?  // "50% Deposit — Hulu Summer Sizzle"
  issueDate     DateTime @default(now())
  dueDate       DateTime
  paymentTerms  String?  // human-readable label, e.g. "Net 30", "Due on Receipt"
  poNumber      String?  // client's PO

  // Embedded line items — invoices don't share the budget tree
  // [{ description, quantity, unit, rateCents, lineTotalCents, notes }]
  lineItems     Json     @default("[]")

  subtotalCents Int      @default(0)
  taxPct        Decimal  @default(0) @db.Decimal(6, 4)
  taxCents      Int      @default(0)
  discountCents Int      @default(0)
  totalCents    Int      @default(0)
  amountPaidCents Int    @default(0)

  // Notes / terms shown to client
  notes         String?  @db.Text
  terms         String?  @db.Text

  status        InvoiceStatus @default(DRAFT)
  sentAt        DateTime?
  publicTokenExpiresAt DateTime? // when the public /i/[token] URL stops working (null = never)
  firstViewedAt DateTime?
  lastViewedAt  DateTime?
  viewCount     Int      @default(0)
  paidAt        DateTime?
  paymentMethod String?  // freeform v1; enum later when Stripe lands
  paymentRef    String?  // wire confirmation #, check #, etc.

  createdById   String?
  createdBy     User?    @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  views         InvoiceView[]

  @@unique([workspaceId, number])
  @@index([projectId])
  @@index([clientId])
  @@index([workspaceId, status])
  @@index([dueDate])
}

model InvoiceView {
  id           String   @id @default(cuid())
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  viewedAt     DateTime @default(now())
  ip           String?
  userAgent    String?  @db.Text
  referer      String?

  @@index([invoiceId])
}

// =============================================================
// GLOBAL LIBRARY — rate card + template catalog
// Seeded by admins; copied into new workspaces on creation.
// Edits to workspace copies never touch these globals.
// =============================================================

model GlobalRateCard {
  id               String       @id @default(cuid())
  role             String       // "Videographer", "Gaffer", "1st AC"
  category         RateCategory
  defaultUnit      RateUnit
  defaultRateCents Int          // money in cents
  notes            String?      @db.Text
  isFeatured       Boolean      @default(false) // featured = seeded into every new workspace
  searchTokens     String?      // pre-computed lowercase tokens
  sortOrder        Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model GlobalTemplate {
  id           String       @id @default(cuid())
  name         String       // "Music Video — Standard Crew"
  description  String?      @db.Text
  shootType    ShootType
  templateKind TemplateKind @default(FULL) // FULL = seeds entire budget; PACKAGE = add-on building block
  structure    Json         // same shape as BudgetTemplate.structure
  isFeatured   Boolean      @default(false)
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// =============================================================
// CALL SHEETS
// =============================================================

enum CallSheetStatus {
  DRAFT
  SENT   // link shared with crew
  FINAL  // locked for the day
}

model CallSheet {
  id            String   @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title         String   // "Day 1 — Studio A" (auto-populated, editable)
  shootDate     DateTime // the date of the shoot
  generalCall   String   @default("07:00") // HH:MM string
  status        CallSheetStatus @default(DRAFT)
  publicToken   String   @unique @default(dbgenerated("gen_random_uuid()::text")) // /cs/[token]

  // Location
  locationName    String?
  locationAddress String?  // full street address — used for geocoding
  locationLat     Float?   // cached after geocode
  locationLng     Float?   // cached after geocode
  parkingAddress  String?
  locationNotes   String?  @db.Text

  // Auto-fetched data (cached on record, refreshable)
  // { name, address, phone, distanceKm, lat, lng }
  hospitalInfo    Json?
  // { high, low, conditions, windKph, precipPct, sunrise, sunset, fetchedAt }
  weather         Json?

  // Point of contact for the day (replaces emergencyContact)
  // { name, title, phone, email }
  pointOfContact  Json?

  // Talent — flat list of on-screen talent
  // [{ name, role, callTime, phone, email }]
  talent          Json     @default("[]")

  // Crew — array of dept groups
  // [{ dept: "Camera", members: [{ name, role, callTime, phone, email }] }]
  crew            Json     @default("[]")

  // Schedule — ordered time blocks
  // [{ startTime: "07:00", endTime?: "08:00", label: "...", whoNeeded?: "...", notes?: "..." }]
  schedule        Json     @default("[]")

  // Additional contacts (venue POC, client rep, etc.)
  // [{ name, role, company, phone, email }]
  otherContacts   Json     @default("[]")

  // Logistics
  cateringInfo    String?  @db.Text
  notes           String?  @db.Text

  // Schedule integration
  locationId        String?
  location          Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  shootDayId        String?
  shootDay          ShootDay?  @relation(fields: [shootDayId], references: [id], onDelete: SetNull)
  scheduleSnapshot  Json?      // frozen copy of schedule entries at last sync
  scheduleSyncedAt  DateTime?  // timestamp of last sync; divergence computed at read time

  sentAt          DateTime?
  publicTokenExpiresAt DateTime? // when the public /cs/[token] URL stops working (null = never)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
  @@index([workspaceId])
  @@index([shootDate])
  @@index([shootDayId])
}

// =============================================================
// ACTUALS — track real spend against a budget phase
// =============================================================

model ActualSheet {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetId    String
  budget      Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  phaseId     String    // which phase this tracks (soft ref — phase can be deleted)

  name                 String  @default("Actuals")
  // If set, use this as the "billed" revenue figure for margin calc.
  // If null, the budget grand total (with markup + tax) is used instead.
  revenueOverrideCents Int?
  notes                String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries ActualEntry[]

  @@index([workspaceId])
  @@index([projectId])
  @@index([budgetId])
}

enum ActualStatus {
  PENDING
  APPROVED
}

model ActualEntry {
  id            String      @id @default(cuid())
  actualSheetId String
  actualSheet   ActualSheet @relation(fields: [actualSheetId], references: [id], onDelete: Cascade)

  // Soft references — no FK constraint. LineItems and Accounts are hard-deleted;
  // if the source row disappears the entry stays (just loses its budget comparison).
  lineItemId  String?  // null = ad-hoc / unplanned entry
  accountId   String?  // which account this belongs to (for grouping in the UI)

  description     String
  actualCents     Int          @default(0)   // what was actually spent on this line
  notes           String?      @db.Text
  isAdHoc         Boolean      @default(false) // true = not present in the original budget
  order           Int          @default(0)

  // F1 additions
  date            DateTime?                    // date of expense / shoot day
  vendorContactId String?                      // soft ref to Contact.id (no FK — contacts are soft-deleted)
  status          ActualStatus @default(PENDING)

  receipts  Receipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([actualSheetId])
}

// =============================================================
// ROLODEX — contact directory + project crew roster
// =============================================================

// A person in the workspace's contact directory (Rolodex).
// UI and full CRUD comes in Phase 2; schema is here now so ProjectMember can FK into it.
model Contact {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name         String
  email        String?
  phone        String?
  instagram    String?   // handle, no @
  website      String?
  notes        String?   @db.Text
  avatarUrl    String?

  // Primary role is what they're known as; secondaryRoles is a JSON String[]
  // of other hats they wear (e.g. ["Gaffer", "Grip"]).
  primaryRole     String            // e.g. "Director of Photography"
  secondaryRoles  Json @default("[]") // String[]

  // Rate defaults — can be overridden per-project in ProjectMember
  defaultRateCents Int?
  defaultRateUnit  RateUnit @default(DAY)

  // Kit — if this person comes with their own gear, enabling hasKit will auto-insert
  // a companion EQUIPMENT line item whenever they're added to a budget as CREW.
  hasKit       Boolean  @default(false)
  kitRateCents Int?     // day-rate for the kit, in cents
  kitName      String?  // e.g. "Sony FX3 Package"; defaults to "{name}'s Kit" if null

  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projectMembers ProjectMember[]
  lineItems      LineItem[]

  @@index([workspaceId])
  @@index([workspaceId, archivedAt])
}

// A crew/talent member assigned to a specific project.
// Can be linked to a Contact in the Rolodex or entered ad-hoc.
model ProjectMember {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Denormalized for IDOR protection — backfilled via scripts/backfill-workspace-ids.ts.
  workspaceId String?

  // Optional link to the Rolodex contact. Null = ad-hoc entry not in the directory.
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  // Their role ON THIS PROJECT (may differ from contact.primaryRole)
  role        String
  // Department for call-sheet grouping (e.g. "Camera", "G&E", "Production")
  department  String?

  // Denormalised name + contact info — copied from Contact at insert time,
  // or entered manually. Stays correct even if the Contact is later edited.
  name        String
  email       String?
  phone       String?

  // Rate for THIS project (overrides contact.defaultRate when set)
  rateCents   Int?
  rateUnit    RateUnit @default(DAY)

  // Call sheet scheduling
  callTime    String?  // HH:MM, e.g. "07:00"

  // Set to true when a newly-won proposal no longer lists this member's role.
  // Cleared when the user confirms ("yes, keep them") or when a future won proposal
  // re-includes the role. Unassigned placeholders with this flag set are deleted outright.
  mismatchFlag Boolean @default(false)

  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([contactId])
  @@index([workspaceId])
}

// =============================================================
// WORKSPACE INVITATIONS — email-based invite with token
// =============================================================

model WorkspaceInvitation {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  email         String
  role          UserRole  @default(PRODUCER)
  token         String    @unique @default(cuid())  // sent in the invite URL /invite/[token]
  invitedByName String?   // display name of the person who sent the invite

  expiresAt     DateTime  // typically NOW + 7 days
  acceptedAt    DateTime? // null = still pending

  createdAt     DateTime @default(now())

  @@index([workspaceId])
  @@index([token])
}

// =============================================================
// PAYMENTS — provider config, checkout attempts, webhook dedup
// =============================================================

enum PaymentProvider {
  NONE
  STRIPE
  HELCIM
}

// One row per workspace — controls which payment provider is active.
// Created on first enable; provider = NONE means payments are off (wire/ACH fallback shown).
model WorkspacePaymentConfig {
  id          String          @id @default(cuid())
  workspaceId String          @unique
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider    PaymentProvider @default(NONE)

  // ── Entitlement flag ──────────────────────────────────────────────────────
  // Helcim is invite-only. No UI exists to flip this — set via SQL / admin backend.
  helcimEnabled Boolean @default(false)

  // ── Stripe Connect (Standard) — only identifiers stored, never secrets ────
  stripeAccountId      String?   @unique
  stripeOnboardedAt    DateTime?
  stripeChargesEnabled Boolean   @default(false) // updated by account.updated webhook

  // ── Helcim — references to encrypted credential rows, never raw tokens ────
  helcimCredentialId      String? @unique
  helcimWebhookVerifierId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

// Envelope-encrypted storage for per-workspace payment credentials.
// AES-256-GCM; KEK loaded from CREDENTIAL_KEK_V<n> env vars.
// Plaintext is NEVER stored — ui shows last4 only.
// See src/lib/crypto/credentials.ts for the full implementation.
model EncryptedCredential {
  id          String    @id @default(cuid())
  workspaceId String
  kind        String    // 'HELCIM_API_TOKEN' | 'HELCIM_WEBHOOK_VERIFIER'
  ciphertext  Bytes
  iv          Bytes
  authTag     Bytes
  keyVersion  Int
  last4       String    // display-only — never derive anything from this
  createdAt   DateTime  @default(now())
  rotatedAt   DateTime?

  @@index([workspaceId])
}

// Tracks a single checkout attempt for an invoice payment.
// Created by initiatePayment, resolved (SUCCEEDED/FAILED) by the confirm route.
// idempotencyKey prevents double-creation; [provider, providerRef] is unique so
// the same Helcim transactionId can never settle two attempts.
model PaymentAttempt {
  id              String          @id @default(cuid())
  workspaceId     String
  invoiceId       String

  provider        PaymentProvider
  // INITIATED → SUCCEEDED | FAILED | EXPIRED
  status          String

  amountCents     Int
  currency        String          @default("USD")

  // Helcim transactionId — set after successful confirm
  providerRef     String?
  // Our reference sent to the provider at init (as Helcim invoiceNumber) and
  // echoed back on the transaction. Lets an inbound webhook map a bare
  // transactionId back to this attempt even when the browser confirm never fired.
  checkoutRef     String?         @unique
  // HelcimPay.js checkoutToken returned to the client for modal rendering
  checkoutToken   String?
  // SHA-256(secretToken) — stored for audit; raw secretToken never persisted
  secretTokenHash String?

  // One-time key generated per initiatePayment call; prevents double-submission
  idempotencyKey  String          @unique

  createdAt       DateTime        @default(now())
  resolvedAt      DateTime?

  @@index([invoiceId])
  @@index([workspaceId, status])
  // Ensures one Helcim transaction can only ever settle one attempt
  @@unique([provider, providerRef])
}

// Idempotency log for inbound webhooks — prevents the same event from being
// processed twice in a race or retry scenario.
model WebhookEvent {
  id          String          @id @default(cuid())
  provider    PaymentProvider
  eventId     String
  payloadHash String
  processedAt DateTime?
  createdAt   DateTime        @default(now())

  @@unique([provider, eventId])
}

// =============================================================
// AUDIT LOG — workspace activity feed
// =============================================================

// Plain workspaceId column (no FK) so audit events survive workspace soft-delete
// during the 30-day grace period. Hard-purge cron job deletes events first.
model AuditEvent {
  id          String   @id @default(cuid())
  workspaceId String   // plain column — no FK constraint

  // Who did it. Null = system/cron. 'public' = unauthenticated (e.g. client approval).
  actorId     String?

  action      String   // 'proposal.sent', 'proposal.approved', 'invoice.paid', etc.
  entityType  String?  // 'Proposal', 'Invoice', 'CallSheet', 'Workspace', 'Member'
  entityId    String?

  // Arbitrary context: { token, ip, totalCents, email, role } etc.
  metadata    Json?

  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@index([workspaceId, createdAt(sort: Desc)])
}

// =============================================================
// RECEIPTS — file attachments linked to actuals
// =============================================================

model Receipt {
  id            String       @id @default(cuid())
  workspaceId   String
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Optional link to an ActualEntry. Null = "Inbox" (unattached).
  actualEntryId String?
  actualEntry   ActualEntry? @relation(fields: [actualEntryId], references: [id], onDelete: SetNull)

  fileUrl       String       // R2 public URL (permanent)
  fileName      String       // original filename for display
  fileType      String       // MIME type: image/jpeg | image/png | image/webp | application/pdf
  fileSizeBytes Int?         // file size in bytes

  // Details filled in after upload — drive actuals reconciliation
  amountCents   Int?         // amount on this receipt
  merchantName  String?      // vendor / merchant name
  receiptDate   DateTime?    // date of the expense (may differ from upload date)

  uploadedAt    DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([workspaceId])
  @@index([projectId])
  @@index([actualEntryId])
  @@index([projectId, actualEntryId])
}

// =============================================================
// DELIVERY — client-facing deliverable pages
// =============================================================

enum DeliveryPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DeliverableType {
  DELIVERABLE
  SERVICE
  RAW_FOOTAGE
  OTHER
}

enum AssetStatus {
  DRAFT
  SHARED
}

enum EmbedProvider {
  FRAME_IO
  SHADE
  GDRIVE_FILE
  GDRIVE_FOLDER
  DROPBOX_FILE
  DROPBOX_FOLDER
  DIRECT_IMAGE
  DIRECT_VIDEO
  YOUTUBE
  VIMEO
  GENERIC_LINK
}

enum RenderMode {
  IFRAME
  NATIVE_MEDIA
  EXTERNAL_ONLY
}

// One per project (lazy-created). Public URL: /d/[publicToken]
model DeliveryPage {
  id              String              @id @default(cuid())
  workspaceId     String
  projectId       String              @unique
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  publicToken     String              @unique @default(dbgenerated("gen_random_uuid()::text"))
  title           String?
  subtitle        String?
  customMessage   String?             @db.Text
  overview        String?             @db.Text  // rich text block shown between hero and sections (smart-text format)
  coverImageUrl   String?
  status          DeliveryPageStatus  @default(DRAFT)
  lastPublishedAt DateTime?
  sections        DeliverableSection[]
  deliverables    DeliverableAsset[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([workspaceId])
}

// Logical grouping within a DeliveryPage (e.g. "Edited Photos", "Raw Footage")
model DeliverableSection {
  id                  String              @id @default(cuid())
  workspaceId         String
  deliveryPageId      String
  deliveryPage        DeliveryPage        @relation(fields: [deliveryPageId], references: [id], onDelete: Cascade)
  title               String
  description         String?             @db.Text
  orderIndex          Int                 @default(0)
  sourceDeliverableId String?             // back-ref to Phase.deliverables JSON item id
  deliverables        DeliverableAsset[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([deliveryPageId, orderIndex])
  @@index([workspaceId])
}

// One card per deliverable file/link the client can view
model DeliverableAsset {
  id                  String              @id @default(cuid())
  workspaceId         String
  deliveryPageId      String
  deliveryPage        DeliveryPage        @relation(fields: [deliveryPageId], references: [id], onDelete: Cascade)
  sectionId           String?
  section             DeliverableSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  title               String
  description         String?             @db.Text
  orderIndex          Int                 @default(0)
  type                DeliverableType
  status              AssetStatus         @default(DRAFT)
  publicToken         String              @unique @default(dbgenerated("gen_random_uuid()::text"))
  currentVersionId    String?             @unique
  currentVersion      DeliverableVersion? @relation("CurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions            DeliverableVersion[] @relation("AllVersions")
  sourceDeliverableId String?             // which proposal deliverable spawned this
  sourceCardIndex     Int?                // 0-based index within that deliverable's quantity
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([deliveryPageId, orderIndex])
  @@index([sectionId, orderIndex])
  @@index([workspaceId])
}

// Each version is a URL / embed. The asset points to its currentVersion.
model DeliverableVersion {
  id                String           @id @default(cuid())
  workspaceId       String
  deliverableId     String
  deliverable       DeliverableAsset @relation("AllVersions", fields: [deliverableId], references: [id], onDelete: Cascade)
  versionNumber     Int
  url               String
  provider          EmbedProvider
  renderMode        RenderMode
  embedHtml         String?          @db.Text  // sanitized iframe HTML when user pasted an embed
  thumbnailUrl      String?
  note              String?          @db.Text
  isVertical        Boolean          @default(false) // portrait/9:16 content — affects embed container height
  firstClientViewAt DateTime?        // null = unseen badge active; set on first real client view
  createdAt         DateTime         @default(now())
  currentForAsset   DeliverableAsset? @relation("CurrentVersion")

  @@unique([deliverableId, versionNumber])
  @@index([workspaceId])
}

// Append-only view log for analytics + unseen-badge tracking
model DeliverableView {
  id            String   @id @default(cuid())
  workspaceId   String
  deliverableId String
  versionId     String
  ipHash        String   // SHA-256(ip + DELIVERY_VIEW_SALT) — no raw IPs stored
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([deliverableId, versionId])
  @@index([workspaceId])
}

// =============================================================
// SCHEDULE FEATURE — Location, ShootDay, Scene, Schedule, ScheduleEntry
// =============================================================

model Location {
  id               String   @id @default(cuid())
  workspaceId      String
  name             String
  address          String?
  city             String?
  region           String?
  postalCode       String?
  country          String?
  latitude         Float?
  longitude        Float?
  parkingNotes     String?  @db.Text
  accessNotes      String?  @db.Text
  nearestHospital  String?
  hospitalAddress  String?
  hospitalPhone    String?
  hospitalDistance String?
  contactName      String?
  contactPhone     String?
  contactEmail     String?
  scenes           Scene[]
  shootDays        ShootDay[]
  callSheets       CallSheet[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, name])
}

model ShootDay {
  id                String    @id @default(cuid())
  workspaceId       String
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date              DateTime  @db.Date
  orderIndex        Int       @default(0)
  label             String?
  startTime         String?   // "HH:mm"; default 08:00 if null
  primaryLocationId String?
  primaryLocation   Location? @relation(fields: [primaryLocationId], references: [id], onDelete: SetNull)
  scheduleEntries   ScheduleEntry[]
  callSheets        CallSheet[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([projectId, date])
  @@index([projectId, orderIndex])
  @@index([workspaceId])
}

enum IntExt {
  INT
  EXT
  INT_EXT
  CONTINUOUS
}

enum TimeOfDay {
  DAY
  NIGHT
  DUSK
  DAWN
  MORNING
  EVENING
}

model Scene {
  id                String    @id @default(cuid())
  workspaceId       String
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sceneNumber       String?
  setting           String
  description       String?   @db.Text
  synopsis          String?   @db.Text
  intExt            IntExt    @default(INT)
  timeOfDay         TimeOfDay @default(DAY)
  pageCount         String?   // display string e.g. "2 5/8"
  pageEighths       Int?      // numeric (1 page = 8 eighths)
  estimatedDuration Int?      // minutes
  locationId        String?
  location          Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  notes             String?   @db.Text
  castContactIds    String[]  @default([])
  colorOverride     String?   // hex; null = auto-derived from intExt + timeOfDay
  archived          Boolean   @default(false)
  entries           ScheduleEntry[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([projectId])
  @@index([workspaceId])
}

model Schedule {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  isPrimary   Boolean  @default(false)
  columnPrefs Json     @default("{}")
  entries     ScheduleEntry[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([workspaceId])
}

enum EntryKind {
  SCENE
  BANNER
}

enum BannerType {
  MEAL_BREAK
  COMPANY_MOVE
  COFFEE_BREAK
  NOTE
  CUSTOM
}

model ScheduleEntry {
  id                String     @id @default(cuid())
  workspaceId       String
  scheduleId        String
  schedule          Schedule   @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  shootDayId        String?
  shootDay          ShootDay?  @relation(fields: [shootDayId], references: [id], onDelete: SetNull)
  orderIndex        Int        @default(0)
  kind              EntryKind
  // SCENE branch
  sceneId           String?
  scene             Scene?     @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  // BANNER branch
  bannerType        BannerType?
  bannerLabel       String?
  bannerDurationMin Int?
  bannerNote        String?    @db.Text
  // Computed time snapshot (server-maintained)
  computedStartTime String?
  computedEndTime   String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([scheduleId, shootDayId, orderIndex])
  @@index([workspaceId])
}

// =============================================================
// CONTRACT BLOCKS
// =============================================================

enum ContractBlockCategory {
  SOW
  TERMS
  PAYMENT
  IP_RIGHTS
  COMPLIANCE
  CUSTOM
}

enum TriggerKind {
  DELIVERABLE_TYPE
  KEYWORD
  BUDGET_ACCOUNT
}

model ContractBlock {
  id          String                 @id @default(cuid())
  workspaceId String
  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String
  category    ContractBlockCategory  @default(CUSTOM)
  body        String                 @db.Text
  isDefault   Boolean                @default(false)
  isActive    Boolean                @default(true)
  orderIndex  Int                    @default(0)
  triggers    ContractBlockTrigger[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([workspaceId, isActive])
}

model ContractBlockTrigger {
  id          String        @id @default(cuid())
  workspaceId String
  blockId     String
  block       ContractBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  kind        TriggerKind
  matchValue  String

  @@index([blockId])
  @@index([workspaceId])
}

model GlobalContractBlock {
  id         String                       @id @default(cuid())
  title      String
  category   ContractBlockCategory        @default(CUSTOM)
  body       String                       @db.Text
  isDefault  Boolean                      @default(false)
  orderIndex Int                          @default(0)
  isFeatured Boolean                      @default(true)
  triggers   GlobalContractBlockTrigger[]
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt
}

model GlobalContractBlockTrigger {
  id         String              @id @default(cuid())
  blockId    String
  block      GlobalContractBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  kind       TriggerKind
  matchValue String

  @@index([blockId])
}

// =============================================================
// PROPOSAL CONTRACT SECTIONS
// =============================================================

enum AttachSource {
  AUTO     // trigger fired and user confirmed
  MANUAL   // user picked from library or created ad-hoc
  DEFAULT  // block.isDefault — attached when Contract tab first opened
}

model ProposalContractSection {
  id               String       @id @default(cuid())
  workspaceId      String
  proposalId       String
  proposal         Proposal     @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  sourceBlockId    String?      // null = ad-hoc; back-ref to ContractBlock (kept if block later deleted)
  title            String
  body             String       @db.Text
  orderIndex       Int          @default(0)
  attachedBy       AttachSource @default(MANUAL)
  editedFromSource Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([proposalId, orderIndex])
  @@index([workspaceId])
}
